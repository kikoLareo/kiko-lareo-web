---
// Nav fijo. En portada lleva los enlaces de sección; en subpáginas,
// vuelta a la portada + etiqueta contextual.
interface Props {
  variante?: 'portada' | 'subpagina';
  etiqueta?: string;
}

const { variante = 'portada', etiqueta } = Astro.props;
---

<nav class="nav">
  {variante === 'portada' ? (
    <>
      <a href="#top" class="nav-logo">KIKO LAREO®</a>
      <div class="nav-links">
        <a href="#trabajo"><span class="nav-num">01</span> TRABAJO</a>
        <a href="#sobre"><span class="nav-num">02</span> SOBRE MÍ</a>
        <a href="#servicios"><span class="nav-num">03</span> QUÉ APORTO</a>
        <a href="#contacto"><span class="nav-num">04</span> CONTACTO</a>
      </div>
    </>
  ) : (
    <>
      <a href="/" class="nav-logo">← KIKO LAREO®</a>
      {etiqueta && <span class="nav-label">{etiqueta}</span>}
    </>
  )}
</nav>
