---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Imagen para compartir en redes (ruta relativa o absoluta) */
  ogImage?: string | null;
  /** Bloques JSON-LD (schema.org) a inyectar en el <head> */
  jsonLd?: object[];
  /** true en páginas que Google no debe indexar (ej: /gracias) */
  noindex?: boolean;
}

const { title, description, ogImage, jsonLd = [], noindex = false } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImg = ogImage ? new URL(ogImage, Astro.site).toString() : undefined;
---

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<title>{title}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex" />}

<script is:inline>
  // Los correos de Netlify Identity (invitación al panel, recuperación de
  // contraseña) traen un token en el enlace y aterrizan en la portada;
  // el panel vive en /admin, así que reenviamos el token allí.
  (function () {
    var h = window.location.hash;
    if (
      /^#(invite_token|recovery_token|confirmation_token|email_change_token)=/.test(h) &&
      window.location.pathname.indexOf('/admin') !== 0
    ) {
      window.location.replace('/admin/' + h);
    }
  })();
</script>
<link rel="canonical" href={canonical} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="Kiko Lareo® — Fotógrafo y Videógrafo" />
<meta property="og:locale" content="es_ES" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
{ogImg && <meta property="og:image" content={ogImg} />}
<meta name="twitter:card" content={ogImg ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
{ogImg && <meta name="twitter:image" content={ogImg} />}

{jsonLd.map((bloque) => (
  <script type="application/ld+json" set:html={JSON.stringify(bloque)} />
))}

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;600;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
<a href="#contenido" class="skip">SALTAR AL CONTENIDO →</a>
<slot />
<script>
  // Tarjetas con historia: HISTORIA ↻ gira la tarjeta
  document.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('.flip-btn');
    if (btn) btn.closest('.flip')?.classList.toggle('flipped');
  });
</script>
</body>
</html>
