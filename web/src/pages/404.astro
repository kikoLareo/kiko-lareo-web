---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
---

<Base title="Página no encontrada — Kiko Lareo®" description="Esta página no existe. Vuelve a la portada de Kiko Lareo, fotógrafo y videógrafo en A Coruña.">

<Nav variante="subpagina" etiqueta="ERROR 404" />

<main style="padding:72px 40px; min-height:60vh">
  <h1 class="contact-title" style="margin:0; color:var(--negro)">NADA POR AQUÍ</h1>
  <p style="font-size:21px; line-height:1.55; max-width:640px; margin:28px 0 0">
    Esta página no existe o se movió. Como un disparo desenfocado: se borra y se vuelve a encuadrar.
  </p>
  <a href="/" class="link" style="margin-top:32px; font-family:var(--mono); font-size:13px">← VOLVER A LA PORTADA</a>
</main>

<footer class="footer-bar">
  <span>© {new Date().getFullYear()} KIKO LAREO®</span><a href="/#contacto">CONTACTO →</a>
</footer>

</Base>
