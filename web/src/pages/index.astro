---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Slot from '../components/Slot.astro';
import FlipCard from '../components/FlipCard.astro';
import { CATEGORIAS } from '../lib/categorias';
import { negocioLocal } from '../lib/seo';

const [ajustes] = await getCollection('paginas');
const g = ajustes.data;

const jsonLd = [
  negocioLocal(Astro.site!, {
    email: g.email,
    telefono: g.telefono,
    direccion: g.direccion,
    redes: g.redes,
    imagen: g.seo.imagen_compartir ?? g.hero_imagen,
  }),
];

const fotos = (await getCollection('fotos')).sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime()
);
const proyectos = (await getCollection('proyectos')).sort(
  (a, b) => b.data.fecha.getTime() - a.data.fecha.getTime()
);

// Por categoría: la tarjeta con historia más reciente + las 2 fotos más
// recientes. Si faltan fotos, se muestran los huecos etiquetados.
const secciones = CATEGORIAS.map((cat) => {
  const propias = fotos.filter((f) => f.data.categoria === cat.id);
  const card = propias.find((f) => f.data.historia);
  const resto = propias.filter((f) => f !== card).slice(0, 2);
  const ultimoProyecto = proyectos.find((p) => p.data.categoria === cat.id);

  type Celda =
    | { tipo: 'card'; foto: typeof card }
    | { tipo: 'foto'; foto: (typeof resto)[number] }
    | { tipo: 'hueco'; etiqueta: string };

  const celdas: Celda[] = [];
  const fotosPendientes = [...resto];
  for (let i = 0; i < 3; i++) {
    if (i === cat.cardPos) {
      celdas.push({ tipo: 'card', foto: card });
    } else if (fotosPendientes.length) {
      celdas.push({ tipo: 'foto', foto: fotosPendientes.shift()! });
    } else {
      celdas.push({ tipo: 'hueco', etiqueta: cat.placeholders[i] });
    }
  }

  return { cat, celdas, ultimoProyecto };
});

const marquesina = `${g.marquesina.trim()} `;

// Selección de proyectos de portada: los marcados como destacados o,
// si no hay ninguno, los más recientes (máximo 6).
const marcados = proyectos.filter((p) => p.data.destacado);
const seleccion = (marcados.length ? marcados : proyectos).slice(0, 6);

// Código de archivo autogenerado ([ KL—001 ]): posición cronológica del
// proyecto entre todos los publicados. Kiko nunca lo escribe a mano.
const cronologicos = [...proyectos].sort(
  (a, b) => a.data.fecha.getTime() - b.data.fecha.getTime()
);
const codigo = (p: (typeof proyectos)[number]) =>
  `KL—${String(cronologicos.indexOf(p) + 1).padStart(3, '0')}`;

// Manifiesto: la última palabra de la segunda línea se acentúa en rojo
const maniPalabras = g.manifiesto.despues.trim().split(' ');
const maniUltima = maniPalabras.pop();
const maniResto = maniPalabras.join(' ');

const [cierre1, cierre2] = g.cierre.split('\n');

// Titular gigante del hero, línea a línea; el ® final se hace pequeño
const heroLineas = g.hero_titular
  .split('\n')
  .map((l) => l.trim())
  .filter(Boolean);
---

<Base
  title="Kiko Lareo® — Fotógrafo y Videógrafo en A Coruña, Galicia"
  description={g.seo.descripcion}
  ogImage={g.seo.imagen_compartir ?? g.hero_imagen}
  jsonLd={jsonLd}
>

<Nav />

<!-- Hero: foto de fondo a sangre completa, dentro de las letras (máscara)
     o con la foto en tarjeta. El titular es el concepto de la marca. -->
{g.hero_estilo === 'fondo' && g.hero_imagen ? (
  <header id="top" class="hero-bg">
    <div class="bg"><Slot imagen={g.hero_imagen} etiqueta="" /></div>
    <div class="scrim" aria-hidden="true"></div>
    <div class="contenido">
      <div class="hero-meta">
        <div set:html={g.claim_izquierda.replace(/\n/g, '<br>')} />
        <div class="right" set:html={g.claim_derecha.replace(/\n/g, '<br>')} />
      </div>
      <h1 class="hero-title" style="margin:0">
        <span class="sr-only">Kiko Lareo, fotógrafo y videógrafo en A Coruña — </span>
        {heroLineas.map((l) =>
        l.endsWith('®') ? (
          <span>{l.slice(0, -1)}<sup>®</sup></span>
        ) : (
          <span>{l}</span>
        )
      )}
      </h1>
    </div>
  </header>
) : g.hero_estilo === 'letras' && g.hero_imagen ? (
  <header id="top" class="hero hero-letras">
    <div class="hero-meta">
      <div set:html={g.claim_izquierda.replace(/\n/g, '<br>')} />
      <div class="right" set:html={g.claim_derecha.replace(/\n/g, '<br>')} />
    </div>
    <h1
      class="hero-title mask"
      style={`margin:0; background-image:url('${g.hero_imagen}')`}
    >
      <span class="sr-only">Kiko Lareo, fotógrafo y videógrafo en A Coruña — </span>
      {heroLineas.map((l) =>
        l.endsWith('®') ? (
          <span>{l.slice(0, -1)}<sup>®</sup></span>
        ) : (
          <span>{l}</span>
        )
      )}
    </h1>
  </header>
) : (
  <header id="top" class="hero">
    <div class="hero-meta">
      <div set:html={g.claim_izquierda.replace(/\n/g, '<br>')} />
      <div class="right" set:html={g.claim_derecha.replace(/\n/g, '<br>')} />
    </div>
    <h1 class="hero-title" style="margin:0">
      <span class="sr-only">Kiko Lareo, fotógrafo y videógrafo en A Coruña — </span>
      {heroLineas.map((l) =>
        l.endsWith('®') ? (
          <span>{l.slice(0, -1)}<sup>®</sup></span>
        ) : (
          <span>{l}</span>
        )
      )}
    </h1>
    <div class="hero-media">
      <div>
        <Slot imagen={g.hero_imagen} etiqueta="Foto principal — súbela desde el panel (Páginas → Portada)" />
      </div>
    </div>
  </header>
)}

<!-- Marquesina -->
<div class="marquee" aria-hidden="true">
  <div class="marquee-inner">
    <span>{marquesina}</span><span>{marquesina}</span>
  </div>
</div>

<!-- Accesos rápidos -->
<div class="quicklinks">
  {CATEGORIAS.map((c) => (
    <a href={`#${c.id}`}>({c.num}) {c.titulo}</a>
  ))}
</div>

<main>
<div id="trabajo"></div>

<!-- Selección de proyectos: numerados como archivo y con su frase propia -->
{seleccion.length > 0 && (
  <section class="featured" id="proyectos">
    <div class="cat-header first">
      <span class="cat-num">(SELECCIÓN)</span>
      <h2 class="cat-title" style="margin:0">PROYECTOS</h2>
    </div>
    <div class="featured-grid">
      {seleccion.map((p) => (
        <a href={`/proyectos/${p.id}/`} class="featured-card">
          <div class="cover">
            <Slot imagen={p.data.portada} alt={`${p.data.titulo} — ${p.data.cliente}`} etiqueta={`Portada de ${p.data.titulo}`} />
          </div>
          <div class="featured-code">
            [ {codigo(p)} ] / {p.data.categoria.toUpperCase()}{p.data.localidad ? ` / ${p.data.localidad.toUpperCase()}` : ''}
          </div>
          <div class="featured-title">{p.data.titular}</div>
          <div class="featured-meta">{p.data.cliente} · {p.data.anio}</div>
        </a>
      ))}
    </div>
  </section>
)}

{secciones.map(({ cat, celdas, ultimoProyecto }, i) => (
  <section id={cat.id}>
    <div class={`cat-header${i === 0 && seleccion.length === 0 ? ' first' : ''}`}>
      <span class="cat-num">({cat.num})</span>
      <h2 class="cat-title" style="margin:0">{cat.titulo}</h2>
      <div class="cat-aside-group">
        {ultimoProyecto && (
          <a href={`/proyectos/${ultimoProyecto.id}/`} class="link">
            VER PROYECTO: {ultimoProyecto.data.titulo.toUpperCase()} →
          </a>
        )}
        <a href={`/${cat.id}/`} class="link">VER TODO →</a>
      </div>
    </div>
    <div class={`cat-grid ${cat.grid}${cat.tall ? ' tall' : ''}${i === secciones.length - 1 ? ' last' : ''}`}>
      {celdas.map((celda, pos) =>
        celda.tipo === 'card' ? (
          celda.foto ? (
            <FlipCard
              class="cat-cell"
              imagen={celda.foto.data.imagen}
              alt={celda.foto.data.alt}
              etiqueta={celda.foto.data.titulo}
              historia={celda.foto.data.historia!}
            />
          ) : (
            <div class="cat-cell"><Slot etiqueta={cat.placeholders[pos]} /></div>
          )
        ) : celda.tipo === 'foto' ? (
          <div class="cat-cell">
            <Slot imagen={celda.foto.data.imagen} alt={celda.foto.data.alt} etiqueta={celda.foto.data.titulo} />
          </div>
        ) : (
          <div class="cat-cell"><Slot etiqueta={celda.etiqueta} /></div>
        )
      )}
    </div>
  </section>
))}

<!-- Manifiesto: se revela al llegar con el scroll -->
<section class="manifiesto">
  <p class="mani-linea">{g.manifiesto.antes}</p>
  <p class="mani-linea mani-dos">
    {maniResto} <span class="mani-acento">{maniUltima}</span>
  </p>
</section>

<!-- Reel -->
<section class="reel">
  <div class="reel-header">
    <span class="reel-title">{g.reel.titulo}</span>
    <span class="reel-label">{g.reel.etiqueta}</span>
  </div>
  <div class="reel-media">
    <Slot imagen={g.reel.imagen} etiqueta="Fotograma del reel — aquí se incrusta el vídeo" />
    <div class="play-overlay"><div class="play-btn">PLAY</div></div>
  </div>
</section>

<!-- Sobre mí -->
<section id="sobre" class="about">
  <div class="about-photo"><Slot imagen={g.sobre_mi.retrato} etiqueta="Retrato de Kiko" /></div>
  <div>
    <h2 class="section-title" style="margin:0">SOBRE MÍ</h2>
    {g.sobre_mi.parrafos.map((p) => <p>{p}</p>)}
    <div class="about-stats">
      {g.sobre_mi.stats.map((s) => (
        <div>{s.linea1}<br>{s.linea2}</div>
      ))}
    </div>
  </div>
</section>

<!-- Qué aporto: las maneras de entrar en un proyecto, sin lista cerrada -->
<section id="servicios" class="services">
  {g.aportes.length > 0 ? (
    <>
      <h2 class="section-title">PUEDO ENTRAR EN UN PROYECTO PARA…</h2>
      {g.aportes.map((a, i) => (
        <div class="service-row">
          <span class="aporte-titulo"><span class="aporte-num">0{i + 1}</span> {a.titulo}</span>
          <span class="aporte-texto">{a.texto}</span>
        </div>
      ))}
      {g.aportes_cierre && <p class="aportes-cierre">{g.aportes_cierre}</p>}
    </>
  ) : (
    <>
      <h2 class="section-title">SERVICIOS</h2>
      {g.servicios.map((s) => (
        <div class="service-row"><span>{s.nombre}</span><span class="tag">{s.tag}</span></div>
      ))}
    </>
  )}
</section>

<!-- Clientes -->
<section class="clients">
  <div class="clients-label">HAN CONFIADO EN MÍ</div>
  <div class="clients-list">
    {g.clientes.map((c) => <span>{c}</span>)}
  </div>
</section>

<!-- Contacto -->
<section id="contacto" class="contact">
  <h2 class="contact-title" style="margin:0">HABLEMOS</h2>
  <div class="contact-grid">
    <div>
      <a href={`mailto:${g.email}`} class="contact-email">{g.email}</a>
      <div class="contact-socials">
        {g.redes.map((r) => (
          <a href={r.url || '#'} target="_blank" rel="noopener">{r.nombre.toUpperCase()} ↗</a>
        ))}
      </div>
    </div>
    <form class="contact-form" id="contact-form" data-email={g.email}>
      <input type="text" name="nombre" placeholder="Nombre" required />
      <input type="email" name="email" placeholder="Email" required />
      <textarea name="mensaje" placeholder="Cuéntame tu proyecto" rows="3" required></textarea>
      <button type="submit">ENVIAR →</button>
    </form>
  </div>
  <a href={`mailto:${g.email}`} class="cierre-cta">
    <span>{cierre1}</span>
    {cierre2 && <span>{cierre2} →</span>}
  </a>
  <div class="registro">
    <span>KIKO LAREO® ─────────── HISTORIAS CON LUZ</span>
    <span><span class="rec" aria-hidden="true">●</span> REC / KL_ARCHIVE</span>
  </div>
  <div class="contact-footer">
    <span>© {new Date().getFullYear()} KIKO LAREO®</span><span>{g.localizacion}</span>
  </div>
</section>
</main>

<script>
  // Manifiesto: las dos líneas se revelan al llegar con el scroll.
  // Con "reducir movimiento" activado, el CSS las muestra directamente.
  const mani = document.querySelector('.manifiesto');
  if (mani) {
    const io = new IntersectionObserver(
      (entradas) => {
        entradas.forEach((e) => {
          if (e.isIntersecting) {
            mani.classList.add('visible');
            io.disconnect();
          }
        });
      },
      { threshold: 0.4 }
    );
    io.observe(mani);
  }
</script>

</Base>
